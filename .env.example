# Local environment — copy to `.env.local` and adjust values.

MONGODB_URI=mongodb://127.0.0.1:27017/localpro

# Plain MVP password for `/login`.
ADMIN_PASSWORD=admin123

# Used to sign the session cookie. Required in production; dev falls back if unset (see `lib/session.ts`).
AUTH_SECRET=replace-with-a-long-random-string
