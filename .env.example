# Local environment — copy to `.env.local` and adjust values.

MONGODB_URI=mongodb://127.0.0.1:27017/localpro

# Admin login password. SECURITY: Change this immediately!
# Must be at least 12 characters in production. Generate a strong random string.
# Example: openssl rand -base64 32
ADMIN_PASSWORD=change-me-to-a-strong-password

# Used to sign the session cookie. SECURITY: Use a random 32+ character string in production.
# Example: openssl rand -base64 32
AUTH_SECRET=change-me-to-a-long-random-string

# Optional: transactional email via Resend (https://resend.com). Without this key, production skips sending; development logs to the server console.
# RESEND_API_KEY=re_xxxx
# EMAIL_FROM=LocalPro <onboarding@resend.dev>

# Secures GET/POST /api/cron/notifications (Bearer token or ?secret=). Schedule hourly from your host or GitHub Actions.
# CRON_SECRET=replace-with-a-long-random-string

# Shift reminders: email worker when shift start is approximately this many hours away (cron should run ~hourly).
# SHIFT_REMINDER_HOURS_BEFORE=24
# SHIFT_REMINDER_WINDOW_MINUTES=90

# Payment reminder cron: only invoices with a due_date; remind when due within this many days (or overdue). Cooldown between emails per invoice.
# PAYMENT_REMINDER_LOOKAHEAD_DAYS=3
# PAYMENT_REMINDER_COOLDOWN_DAYS=7
